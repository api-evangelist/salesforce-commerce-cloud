          {
            "name": "siteId",
            "value": "",
            "type": "query"
          },
          {
            "name": "q",
            "value": "",
            "type": "query"
          },
          {
            "name": "refine",
            "value": "",
            "type": "query"
          },
          {
            "name": "sort",
            "value": "",
            "type": "query"
          },
          {
            "name": "currency",
            "value": "",
            "type": "query"
          },
          {
            "name": "locale",
            "value": "",
            "type": "query"
          },
          {
            "name": "offset",
            "value": "",
            "type": "query"
          },
          {
            "name": "limit",
            "value": "",
            "type": "query"
          }
        ]
      },
      "docs": "Product search"
